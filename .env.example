# === 推送渠道（至少配一个）===
# Server酱: https://sct.ftqq.com/ 注册获取
SERVERCHAN_SENDKEY=

# PushPlus: https://www.pushplus.plus/ 注册获取
PUSHPLUS_TOKEN=

# 企业微信群机器人 webhook URL
WECOM_BOT_WEBHOOK=

# Qmsg酱: https://qmsg.zendee.cn/
QMSG_KEY=
QMSG_QQ=

# === LLM 接口（岗位分析 + 智能播报）===
# 支持 DeepSeek / OpenAI / Zhipu 等兼容 OpenAI 格式的 API
# DeepSeek 推荐：https://platform.deepseek.com/ 注册，极低成本（百万token约1元）
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# === Gmail 监控 ===
# 需要 credentials.json（Google Cloud OAuth），参考 README 配置
# 代理设置（访问 googleapis.com 需要，留空则不使用代理）
HTTP_PROXY=
HTTPS_PROXY=
